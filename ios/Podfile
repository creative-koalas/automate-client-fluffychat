# 阿里云推送 SDK 源
source 'https://github.com/aliyun/aliyun-specs.git'
# 使用 CDN 方式访问 CocoaPods specs (更快更稳定)
source 'https://cdn.cocoapods.org/'

# Uncomment this line to define a global platform for your project
platform :ios, '14.4'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # 阿里云一键登录 SDK
  pod 'ATAuthSDK', :path => 'Runner/Frameworks'

end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # ensure all dependencies are using SQLCipher instead of SQLite
      xcconfig_path = config.base_configuration_reference.real_path
      xcconfig = File.read(xcconfig_path)
      new_xcconfig = xcconfig.sub(' -l"sqlite3"', '')
      File.open(xcconfig_path, "w") { |file| file << new_xcconfig }

      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.4'
      config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = 'i386'

      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_MICROPHONE=1',
      ]

      config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
      unless config.build_settings['OTHER_LDFLAGS'].include?('-ObjC')
        config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
      end
    end
  end
  flutter_post_install(installer) if defined?(flutter_post_install)

  # 修复 Flutter 3.38+ 的 Flutter-ObjC 引用问题
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      other_ldflags = config.build_settings['OTHER_LDFLAGS']
      if other_ldflags.is_a?(Array)
        config.build_settings['OTHER_LDFLAGS'] = other_ldflags.map { |f| f == 'Flutter-ObjC' ? 'Flutter' : f }
      elsif other_ldflags.is_a?(String)
        config.build_settings['OTHER_LDFLAGS'] = other_ldflags.gsub('Flutter-ObjC', 'Flutter')
      end
    end
  end

  pbxproj_path = "#{installer.pods_project.path}/project.pbxproj"
  if File.exist?(pbxproj_path)
    text = File.read(pbxproj_path)
    if text.include?('Flutter-ObjC')
      File.write(pbxproj_path, text.gsub('Flutter-ObjC', 'Flutter'))
      puts "✅ 已修复 Flutter-ObjC 引用"
    end
  end

  # Xcode upload check may fail if third-party vendored frameworks do not ship dSYMs.
  # Generate missing dSYMs for embedded frameworks after Pods frameworks are copied.
  runner_project_path = File.join(__dir__, 'Runner.xcodeproj')
  if File.exist?(runner_project_path)
    runner_project = Xcodeproj::Project.open(runner_project_path)
    runner_target = runner_project.targets.find { |t| t.name == 'Runner' }
    if runner_target
      phase_name = 'Generate Embedded Framework dSYMs'
      phase = runner_target.shell_script_build_phases.find { |p| p.name == phase_name }
      phase ||= runner_target.new_shell_script_build_phase(phase_name)
      legacy_phase = runner_target.shell_script_build_phases.find { |p| p.name == 'Generate WebRTC dSYM' }
      if legacy_phase && legacy_phase != phase
        runner_target.build_phases.delete(legacy_phase)
      end

      phase.shell_script = <<~SCRIPT
        set -euo pipefail

        if [ "${ACTION}" != "install" ] && [ "${ACTION}" != "archive" ]; then
          exit 0
        fi

        APP_FRAMEWORKS_DIR="${TARGET_BUILD_DIR}/${WRAPPER_NAME}/Frameworks"
        if [ ! -d "${APP_FRAMEWORKS_DIR}" ]; then
          echo "Frameworks directory not found at ${APP_FRAMEWORKS_DIR}, skip dSYM generation."
          exit 0
        fi

        find "${APP_FRAMEWORKS_DIR}" -maxdepth 1 -type d -name "*.framework" | while read -r FRAMEWORK_DIR; do
          FRAMEWORK_NAME="$(basename "${FRAMEWORK_DIR}" .framework)"
          FRAMEWORK_BIN="${FRAMEWORK_DIR}/${FRAMEWORK_NAME}"
          FRAMEWORK_DSYM="${DWARF_DSYM_FOLDER_PATH}/${FRAMEWORK_NAME}.framework.dSYM"

          if [ ! -f "${FRAMEWORK_BIN}" ]; then
            echo "Skip ${FRAMEWORK_NAME}: binary not found at ${FRAMEWORK_BIN}"
            continue
          fi

          if [ -d "${FRAMEWORK_DSYM}" ]; then
            echo "dSYM already exists for ${FRAMEWORK_NAME}, skip."
            continue
          fi

          if dsymutil "${FRAMEWORK_BIN}" -o "${FRAMEWORK_DSYM}"; then
            echo "✅ Generated dSYM for ${FRAMEWORK_NAME}: ${FRAMEWORK_DSYM}"
          else
            echo "⚠️ Failed to generate dSYM for ${FRAMEWORK_NAME}, skip."
          fi
        done
      SCRIPT
      phase.show_env_vars_in_log = '0'
      phase.input_paths = ['${TARGET_BUILD_DIR}/${WRAPPER_NAME}/Frameworks']
      phase.output_paths = []

      embed_pods_phase = runner_target.shell_script_build_phases.find do |p|
        p.name == '[CP] Embed Pods Frameworks'
      end
      if embed_pods_phase
        runner_target.build_phases.delete(phase)
        embed_index = runner_target.build_phases.index(embed_pods_phase)
        runner_target.build_phases.insert(embed_index + 1, phase)
      end

      registrant_phase_name = 'Patch GeneratedPluginRegistrant for qr_code_scanner_plus'
      registrant_phase = runner_target.shell_script_build_phases.find { |p| p.name == registrant_phase_name }
      registrant_phase ||= runner_target.new_shell_script_build_phase(registrant_phase_name)
      registrant_phase.shell_script = <<~SCRIPT
        set -euo pipefail

        GENERATED_REGISTRANT="${SRCROOT}/Runner/GeneratedPluginRegistrant.m"
        if [ ! -f "${GENERATED_REGISTRANT}" ]; then
          exit 0
        fi

        /usr/bin/perl -0pi -e 's/#if __has_include\\(<qr_code_scanner_plus\\/FlutterQrPlusPlugin\\.h>\\)\\n#import <qr_code_scanner_plus\\/FlutterQrPlusPlugin\\.h>\\n#else\\n\\@import qr_code_scanner_plus;\\n#endif\\n//g; s/\\@import qr_code_scanner_plus\\.Swift;\\n//g; s/^\\s*\\[FlutterQrPlusPlugin registerWithRegistrar:\\[registry registrarForPlugin:\\@"FlutterQrPlusPlugin"\\]\\];\\n//mg;' "${GENERATED_REGISTRANT}"
      SCRIPT
      registrant_phase.show_env_vars_in_log = '0'
      registrant_phase.input_paths = ['${SRCROOT}/Runner/GeneratedPluginRegistrant.m']
      registrant_phase.output_paths = []

      sources_phase = runner_target.build_phases.find do |p|
        p.isa == 'PBXSourcesBuildPhase' || p.display_name == 'Sources'
      end
      if sources_phase
        runner_target.build_phases.delete(registrant_phase)
        sources_index = runner_target.build_phases.index(sources_phase)
        runner_target.build_phases.insert(sources_index, registrant_phase)
      end

      runner_project.save
      puts "✅ 已配置 Embedded Framework dSYM 生成脚本"
    end
  end

  generated_registrant_path = File.join(__dir__, 'Runner', 'GeneratedPluginRegistrant.m')
  if File.exist?(generated_registrant_path)
    registrant_text = File.read(generated_registrant_path)
    qr_plugin_imports = [
      <<~IMPORT,
        #if __has_include(<qr_code_scanner_plus/FlutterQrPlusPlugin.h>)
        #import <qr_code_scanner_plus/FlutterQrPlusPlugin.h>
        #else
        @import qr_code_scanner_plus;
        #endif
      IMPORT
      <<~IMPORT,
        @import qr_code_scanner_plus.Swift;
      IMPORT
    ]
    qr_plugin_registration = <<~REGISTRATION
        [FlutterQrPlusPlugin registerWithRegistrar:[registry registrarForPlugin:@"FlutterQrPlusPlugin"]];
    REGISTRATION

    updated_registrant_text = registrant_text
    qr_plugin_imports.each do |import|
      updated_registrant_text = updated_registrant_text.gsub(import, '')
    end
    updated_registrant_text = updated_registrant_text.gsub(qr_plugin_registration, '')

    if updated_registrant_text != registrant_text
      File.write(generated_registrant_path, updated_registrant_text)
      puts "✅ 已改为 AppDelegate 手动注册 qr_code_scanner_plus"
    end
  end

  # Workaround: flutter_vodozemac (cargokit) sometimes writes rust deps into
  # TARGET_TEMP_DIR under DerivedData, which can be removed mid-build by Xcode.
  # Patch build script to use a stable target dir inside plugin workspace.
  vodozemac_build_script = File.join(
    __dir__,
    '.symlinks',
    'plugins',
    'flutter_vodozemac',
    'cargokit',
    'build_pod.sh',
  )
  if File.exist?(vodozemac_build_script)
    original_script = File.read(vodozemac_build_script)
    unless original_script.include?('CARGOKIT_STABLE_TARGET_TEMP_DIR')
      patched_script = original_script.sub(
        'export CARGOKIT_TARGET_TEMP_DIR=$TARGET_TEMP_DIR',
        <<~SCRIPT.strip
          # Keep Cargo target-dir in plugin workspace to avoid transient DerivedData cleanup.
          CARGOKIT_STABLE_TARGET_TEMP_DIR="$PODS_TARGET_SRCROOT/../.cargokit_target/${PLATFORM_NAME}-${CONFIGURATION}"
          mkdir -p "$CARGOKIT_STABLE_TARGET_TEMP_DIR"
          export CARGOKIT_TARGET_TEMP_DIR="$CARGOKIT_STABLE_TARGET_TEMP_DIR"
        SCRIPT
      )
      if patched_script != original_script
        File.write(vodozemac_build_script, patched_script)
        puts "✅ 已修复 flutter_vodozemac Rust 构建目录"
      end
    end
  end

end
